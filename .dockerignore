# Keep the Docker build context small. The Go builds only need source (the Go
# workspace at the repo root ties core + packages/syncserver + apps/*), and the
# cloud image runs its own `npm ci`, so a checked-in node_modules is never wanted.
node_modules
**/node_modules
.git
.github
build
*.log
*.db
**/*.db

# Prebuilt / out-of-tree binaries that would otherwise bloat the context.
/server
apps/server/server
apps/desktop/desktop

# Expo continuous-native-generation output (regenerated by `expo prebuild`).
apps/mobile/ios
apps/mobile/android
.expo
**/.expo
