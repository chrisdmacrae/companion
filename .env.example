# Copy to .env and adjust as needed. Used by compose.yaml (and the server once its
# Postgres store lands — the server currently defaults to local SQLite).

# --- Local development database (docker compose) ---
POSTGRES_USER=companion
POSTGRES_PASSWORD=companion
POSTGRES_DB=companion
POSTGRES_PORT=5432

# --- Server ---
# Connection string for the Postgres store (production path, PLAN §4.2/§10).
DATABASE_URL=postgres://companion:companion@localhost:5432/companion?sslmode=disable
# The server listens here (defaults to :8080).
COMPANION_ADDR=:8080

# --- Logging (server + cloud) ---
# Structured logging via slog. LOG_FORMAT: text (default) or json. LOG_LEVEL: debug, info
# (default), warn, or error. Both the server and cloud log one line per HTTP request.
LOG_FORMAT=text
LOG_LEVEL=info

# Separate database used ONLY by the e2e test suite (make test-server-pg). It is
# truncated on every run, so it must never be your dev DATABASE_URL. Created by the
# compose init script (initdb/).
TEST_DATABASE_URL=postgres://companion:companion@localhost:5432/companion_test?sslmode=disable

# --- Cloud (hosted service: open-core sync API + Stripe billing) ---
# The cloud binary reads the same DATABASE_URL/COMPANION_ADDR as the server, plus these.
# Stripe is configured entirely at runtime; without these keys the cloud still boots and
# gates sync (403) — you just can't run Checkout. Use Stripe *test* keys in dev.
STRIPE_SECRET_KEY=sk_test_...
# The subscription price offered at Checkout (Stripe Dashboard → Products).
STRIPE_PRICE_ID=price_...
# Verifies inbound webhook signatures (Stripe Dashboard → Webhooks, or `stripe listen`).
STRIPE_WEBHOOK_SECRET=whsec_...
# Origin used to build Checkout success/cancel return URLs (defaults to http://localhost:8080).
CLOUD_BASE_URL=http://localhost:8080
# Base URL clients enter in the Companion app's sync settings. The client appends /v1/...,
# so this must point at the API root (/api). Defaults to CLOUD_BASE_URL + /api. Set it to
# the public URL in production, e.g. https://cloud.companion.example/api
SYNC_API_URL=http://localhost:8080/api
# Cross-origin allowlist for the cloud API, comma-separated. "*" allows any origin (the
# default, dev-friendly). In production set the exact origins that call the API, e.g.
# CLOUD_CORS_ORIGINS=https://app.companion.example,https://companion.example
CLOUD_CORS_ORIGINS=*
# Comma-separated emails auto-promoted to admins at boot (if the user already exists).
# CLOUD_ADMIN_EMAILS=you@example.com

# --- Cloud email (SMTP; used for verification emails) ---
# When SMTP_HOST is unset the cloud logs the verification link instead of sending (dev),
# so the flow works without a mail server. Set these to send real email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@companion.example
