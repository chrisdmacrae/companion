# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Compiled desktop binary (out-of-tree build target is build/)
apps/desktop/desktop

# Generated web assets (staged from build/ by `make web-assets`)
apps/web/public/core.wasm
apps/web/public/wasm_exec.js

# Desktop frontend build output (embedded by the Go binary); keep the dir via .gitkeep
apps/desktop/frontend/dist/*
!apps/desktop/frontend/dist/.gitkeep
