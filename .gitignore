# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Compiled desktop binary (out-of-tree build target is build/)
apps/desktop/desktop

# Generated web assets (staged from build/ by `make web-assets`)
apps/web/public/core.wasm
apps/web/public/wasm_exec.js

# Desktop frontend build output (embedded by the Go binary); keep the dir via .gitkeep
apps/desktop/frontend/dist/*
!apps/desktop/frontend/dist/.gitkeep

# Cloud frontend build output (embedded by the Go binary); keep the dir via .gitkeep
apps/cloud/frontend/dist/*
!apps/cloud/frontend/dist/.gitkeep

# Cloud email templates rendered from React Email (embedded by the Go binary); keep the dir
apps/cloud/emails/dist/*
!apps/cloud/emails/dist/.gitkeep

# Expo mobile: continuous-native-generation output (regenerated by `expo prebuild`)
# and local caches. The native module's Swift/Kotlin/podspec/gradle live in
# modules/companion-core and ARE tracked; only the generated app projects are ignored.
apps/mobile/ios/
apps/mobile/android/
apps/mobile/.expo/
