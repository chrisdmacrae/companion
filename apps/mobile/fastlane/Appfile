# Shared identity for every lane. Everything is read from the environment so no
# account IDs or paths are committed — fastlane auto-loads apps/mobile/fastlane/.env
# (copy .env.default -> .env and fill it in; .env is gitignored). See RELEASING.md.

# --- iOS (App Store Connect) ---
app_identifier(ENV.fetch("APP_IDENTIFIER", "cloud.companion.app"))
apple_id(ENV["APPLE_ID"])            # your Apple Developer login email
itc_team_id(ENV["ASC_TEAM_ID"])      # App Store Connect team id (numeric)
team_id(ENV["APPLE_TEAM_ID"])        # Apple Developer portal team id (10-char)

# --- Android (Google Play) ---
package_name(ENV.fetch("PACKAGE_NAME", "cloud.companion.app"))
json_key_file(ENV["PLAY_JSON_KEY_PATH"]) # path to the Play service-account .json
