# Deploy lanes for the Expo app. The native ios/ and android/ dirs are Expo
# prebuild output (gitignored) — lanes regenerate them if missing so a fresh
# checkout / CI runner works. Run from apps/mobile:
#   bundle exec fastlane ios beta        # -> TestFlight
#   bundle exec fastlane android beta    # -> Play internal testing
# See RELEASING.md for the one-time account + signing setup.

APP_IDENTIFIER = ENV.fetch("APP_IDENTIFIER", "cloud.companion.app")
WORKSPACE      = "ios/Companion.xcworkspace"
SCHEME         = "Companion"
AAB_PATH       = "android/app/build/outputs/bundle/release/app-release.aab"

# Expo prebuild output is gitignored; make sure the native project exists before a
# native build. `--no-install` skips pod install here (the ios lane runs it
# explicitly after). Safe to run repeatedly — Expo is idempotent without --clean.
def ensure_prebuild(platform)
  return if Dir.exist?(platform.to_s)
  Dir.chdir("..") { sh("npx expo prebuild --platform #{platform} --no-install") }
end

# App Store Connect API key from env (raw .p8 stored base64 in ASC_KEY_P8). Used
# for both signing (match) and upload (pilot) so there are no interactive 2FA
# prompts, locally or in CI.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8"),
    is_key_content_base64: true,
  )
end

platform :ios do
  desc "Sync signing (match, read-only) — useful to verify credentials"
  lane :signing do
    setup_ci if is_ci
    match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true, api_key: asc_api_key)
  end

  desc "Build and upload to TestFlight (internal testers)"
  lane :beta do
    api_key = asc_api_key
    setup_ci if is_ci # creates a temp keychain on CI so match can install the cert

    ensure_prebuild(:ios)
    cocoapods(podfile: "ios/Podfile")

    match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true, api_key: api_key)

    # Build number must be unique + increasing per upload. Derive from the latest
    # build already on TestFlight so parallel/retried runs don't collide.
    latest = latest_testflight_build_number(app_identifier: APP_IDENTIFIER, api_key: api_key, initial_build_number: 0)
    increment_build_number(xcodeproj: "ios/Companion.xcodeproj", build_number: latest + 1)

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "build",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true, # don't block CI on Apple processing
      distribute_external: false,              # internal testers only
    )
  end
end

platform :android do
  desc "Build AAB and upload to Play internal testing track"
  lane :beta do
    ensure_prebuild(:android)

    # Signing creds are passed as gradle -P properties (env vars alone are invisible to
    # gradle's project.hasProperty, which withAndroidSigning.js keys off). versionCode
    # must be unique per upload — bump from CI (e.g. the run number); else app.json wins.
    gradle_props = {
      "COMPANION_UPLOAD_STORE_FILE"     => ENV["COMPANION_UPLOAD_STORE_FILE"],
      "COMPANION_UPLOAD_STORE_PASSWORD" => ENV["COMPANION_UPLOAD_STORE_PASSWORD"],
      "COMPANION_UPLOAD_KEY_ALIAS"      => ENV["COMPANION_UPLOAD_KEY_ALIAS"],
      "COMPANION_UPLOAD_KEY_PASSWORD"   => ENV["COMPANION_UPLOAD_KEY_PASSWORD"],
      "versionCode"                     => ENV["ANDROID_VERSION_CODE"],
    }.compact # drop unset keys so the debug-keystore fallback still applies locally

    gradle(
      project_dir: "android",
      task: "bundle",
      build_type: "Release",
      properties: gradle_props,
    )

    upload_to_play_store(
      track: "internal",
      aab: AAB_PATH,
      release_status: "completed", # internal track can go live immediately
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true,
    )
  end
end
