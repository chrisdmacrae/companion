{
  "extends": "@companion/config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    // Resolve platform variants the way the web bundler does (Editor.web.tsx,
    // GraphView.web.tsx, …) so the app never typechecks native-only RN modules.
    "moduleSuffixes": [".web", ""]
  },
  "include": ["src", "../design-system/src/react-native.d.ts"]
}
